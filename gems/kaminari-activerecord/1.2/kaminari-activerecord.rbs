module Kaminari
  module ActiveRecordRelationMethods
    def entry_name: (**untyped options) -> String
    def reset: () -> void
    def total_count: (?untyped column_name, untyped _options) -> Integer
    def without_count: () -> void
  end
end

module ActiveRecord
  class Base
    include Kaminari::ConfigurationMethods
    extend Kaminari::ConfigurationMethods::ClassMethods

    def self.page: (?Integer num) -> untyped
  end
end


module ActiveRecord
  class Base
    # Match the 4-param signature introduced in
    # gems/activerecord/7.2/activerecord.rbs (felixefelip/steep#10):
    # ValidatedModel defaults to Model, so callers that pass only the legacy
    # 3 args keep their current behavior.
    module ClassMethods[Model, Relation, PrimaryKey, ValidatedModel = Model]
      def page: (?_ToI num) -> Relation
    end
  end

  class Relation
    module Methods[Model, PrimaryKey, ValidatedModel = Model]
      include Kaminari::ActiveRecordRelationMethods
      include Kaminari::PageScopeMethods
      def page: (?_ToI num) -> self
    end
  end
end
